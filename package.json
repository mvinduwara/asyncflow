{
  "name": "asyncflow-monorepo",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm run start:dev --workspace=backend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev": "npx concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  }
}